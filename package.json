{
  "name": "@feedclip/activity",
  "description": "Local-first activity history engine and React UI for business resources.",
  "license": "MIT",
  "version": "0.2.0",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "migrations",
    "README.md",
    "SECURITY.md",
    "COMPATIBILITY.md",
    "MIGRATIONS.md",
    "API_STABILITY.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./adapters/memory": {
      "types": "./dist/adapters/memory.d.ts",
      "import": "./dist/adapters/memory.js",
      "require": "./dist/adapters/memory.cjs"
    },
    "./adapters/postgres": {
      "types": "./dist/adapters/postgres.d.ts",
      "import": "./dist/adapters/postgres.js",
      "require": "./dist/adapters/postgres.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./migration.sql": "./migrations/001_activity_schema.sql"
  },
  "scripts": {
    "dev": "npm run build:demo && python3 -m http.server 5173 --bind 127.0.0.1 --directory demo-dist",
    "build": "npm run clean && npm run typecheck && npm run build:sdk && npm run build:demo",
    "build:sdk": "node scripts/build-package.mjs && tsc -p tsconfig.package.json",
    "build:demo": "node scripts/build-demo.mjs",
    "clean": "rm -rf dist demo-dist .tmp",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json",
    "preview": "python3 -m http.server 4173 --bind 127.0.0.1 --directory demo-dist",
    "test": "npm run test:coverage",
    "test:unit": "node --import tsx --test tests/*.test.ts tests/*.test.tsx",
    "test:coverage": "node --import tsx --experimental-test-coverage --test-coverage-include=src/activity.ts --test-coverage-include=src/ActivityPanel.tsx --test-coverage-include=src/index.ts --test-coverage-include=src/react.ts --test-coverage-include=src/adapters/*.ts --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 --test tests/*.test.ts tests/*.test.tsx",
    "test:e2e": "npm run build:demo && playwright test",
    "test:package": "node scripts/verify-package.mjs",
    "benchmark:postgres": "npm run build:sdk && node scripts/benchmark-postgres.mjs",
    "api:check": "npm run build:sdk && node scripts/check-public-api.mjs",
    "api:update": "npm run build:sdk && node scripts/check-public-api.mjs --update",
    "verify": "npm test && npm run test:e2e && npm run build && npm run api:check && npm run test:package",
    "prepack": "npm run clean && npm run typecheck && npm run build:sdk && npm test",
    "stackblitz": "npm install --prefix examples/stackblitz && npm run dev --prefix examples/stackblitz -- --host 0.0.0.0"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.1",
    "css.gg": "2.1.4",
    "esbuild": "0.25.12",
    "jsdom": "^29.1.1",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.23.1",
    "typescript": "5.7.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreyshedko/activity.git"
  },
  "bugs": {
    "url": "https://github.com/andreyshedko/activity/issues"
  },
  "homepage": "https://github.com/andreyshedko/activity#readme",
  "engines": {
    "node": ">=20"
  }
}
